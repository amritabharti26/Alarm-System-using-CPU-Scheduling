<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.FCFSReminderScheduler" parent="Theme.AppCompat.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/bg_dark</item>
        <item name="colorPrimaryDark">#000000</item>
        <item name="colorAccent">@color/accent_green</item>

        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="editTextStyle">@style/CustomEditTextStyle</item>
    </style>

    <style name="CustomEditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/edit_text_bg</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>