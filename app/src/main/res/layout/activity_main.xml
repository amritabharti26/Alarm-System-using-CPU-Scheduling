<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏰"
                    android:textSize="24sp"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CPU Scheduler"
                    android:textColor="@color/accent_green"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <TextView
                android:id="@+id/currentTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="00:00:00"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Scheduling Algorithm"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/algoSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="24dp"
            android:paddingHorizontal="12dp" />

        <!-- Alarm Ringing Status -->
        <LinearLayout
            android:id="@+id/statusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg_active"
            android:orientation="horizontal"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            android:gravity="center_vertical">

            <View
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/circle_bg"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔 ALARM RINGING!"
                    android:textColor="@color/accent_green"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/activeReminderText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: R1 | Task Name"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
                <ProgressBar
                    android:id="@+id/executionProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:progressDrawable="@drawable/progress_drawable" />
            </LinearLayout>
        </LinearLayout>

        <!-- Add Reminder Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADD REMINDER"
                android:textColor="@color/accent_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MESSAGE"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:layout_marginBottom="4dp" />
            <EditText
                android:id="@+id/titleInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Task name..."
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ARRIVAL TIME"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/arrivalInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="0"
                        android:inputType="number" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DURATION (SEC)"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/burstInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="3"
                        android:inputType="number" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/extraFieldsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/priorityLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRIORITY (LOW=HIGH)"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/priorityInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="1"
                        android:inputType="number" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/quantumLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TIME QUANTUM"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/quantumInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="2"
                        android:inputType="number" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/addReminderBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/button_bg"
                android:text="+ Add Reminder"
                android:textAllCaps="false"
                android:textColor="@color/bg_dark"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

        <!-- Queue Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <TextView
                    android:id="@+id/queueLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="QUEUE"
                    android:textColor="@color/accent_green"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/resetBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/button_bg_outline"
                    android:text="↺ Reset"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="8dp"
                    android:paddingHorizontal="12dp" />

                <Button
                    android:id="@+id/runBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/button_bg"
                    android:text="▶ Run"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="@color/bg_dark"
                    android:paddingHorizontal="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/queueListText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No reminders in queue"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Results Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXECUTION RESULTS"
                android:textColor="@color/accent_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/resultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Results will appear here"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>